# 生产环境配置示例
# 复制此文件为 .env 后再部署

# 基础应用配置
APP_BASE_URL=http://your-server-ip
APP_CORS_ALLOWED_ORIGINS=http://your-server-ip
VITE_API_BASE_URL=/api

# MySQL（单机 compose 默认使用内置 mysql 服务）
# 如果后端和数据库都在同一台服务器且后端不在容器中，可用 localhost。
# 如果后端跑在容器中，localhost 指向容器自身，请填数据库的可访问地址（如内网 IP）。
DB_HOST=mysql
DB_PORT=3306
DB_NAME=qrcode_channel
DB_USERNAME=root
DB_PASSWORD=your_secure_db_password
MYSQL_DATABASE=qrcode_channel

# 对象存储 - 默认使用单机 MinIO
# MINIO_ROOT_* 供本地 MinIO 服务和初始化容器使用
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=your_secure_minio_password

# MINIO_* 供后端访问对象存储使用
# 单机 MinIO 默认值如下；如改用外部 OBS/S3 兼容服务，修改下面 4 项即可
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=your_secure_minio_password
MINIO_BUCKET=qrcode-images

# 微信公众号配置（JS-SDK 用）
WECHAT_MP_APPID=your_mp_appid
WECHAT_MP_SECRET=your_mp_secret

# 如使用华为云 OBS，请保留 STORAGE_TYPE=minio，
# 并把 MINIO_ENDPOINT / MINIO_ACCESS_KEY / MINIO_SECRET_KEY / MINIO_BUCKET
# 改为 OBS 的 S3 兼容 endpoint 和 AK/SK/bucket。
