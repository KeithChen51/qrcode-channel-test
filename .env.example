# 生产环境配置
# 复制此文件为 .env 并修改配置值

# 数据库密码
DB_PASSWORD=your_secure_db_password

# MinIO配置
MINIO_USER=minioadmin
MINIO_PASSWORD=your_secure_minio_password

# 应用域名（用于生成二维码跳转链接）
APP_BASE_URL=https://your-domain.com
APP_CORS_ALLOWED_ORIGINS=https://your-domain.com

# 微信小程序配置
WECHAT_MINIAPP_APPID=your_miniapp_appid
WECHAT_MINIAPP_SECRET=your_miniapp_secret

# 微信公众号配置（JSSDK用）
WECHAT_MP_APPID=your_mp_appid
WECHAT_MP_SECRET=your_mp_secret

# 华为云OBS配置（如果使用OBS替代MinIO）
# OBS_ENDPOINT=https://obs.cn-south-1.myhuaweicloud.com
# OBS_ACCESS_KEY=your_obs_access_key
# OBS_SECRET_KEY=your_obs_secret_key
# OBS_BUCKET=qrcode-images
