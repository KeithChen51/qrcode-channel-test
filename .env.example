# Production environment example
# Copy this file to .env before deploying.

# Application
# Optional when Nginx forwards Host/X-Forwarded-Proto correctly.
# Set it explicitly if the backend is not reached through the public domain.
APP_BASE_URL=https://qrcode.company.com
APP_CORS_ALLOWED_ORIGINS=https://qrcode.company.com
BACKEND_BIND_HOST=127.0.0.1
BACKEND_PORT=8080

# Admin account
# deploy.sh auto-generates ADMIN_INITIAL_PASSWORD and AUTH_TOKEN_SECRET if blank.
# First startup creates this user and forces password change after login.
ADMIN_USERNAME=admin
ADMIN_INITIAL_PASSWORD=
AUTH_TOKEN_SECRET=
AUTH_TOKEN_TTL_MINUTES=720
AUTH_LOGIN_MAX_ATTEMPTS=5
AUTH_LOGIN_LOCK_MINUTES=10

# Public scan endpoint rate limit
SCAN_RATE_LIMIT_MAX_REQUESTS=60
SCAN_RATE_LIMIT_WINDOW_SECONDS=60

# MySQL
DB_HOST=mysql
DB_PORT=3306
DB_NAME=qrcode_channel
DB_USERNAME=root
DB_PASSWORD=your_secure_db_password
MYSQL_DATABASE=qrcode_channel

# WeChat MP JS-SDK
WECHAT_MP_APPID=your_mp_appid
WECHAT_MP_SECRET=your_mp_secret
